{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    { "src": "/device", "dest": "/frontend/device.html" },
    { "src": "/config", "dest": "/frontend/config.html" },
    { "src": "/resources", "dest": "/frontend/resources.html" },
    { "src": "/admin", "dest": "/frontend/admin.html" },
    { "src": "/", "dest": "/frontend/index.html" },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
