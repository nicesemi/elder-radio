# ============================================
# 老年收音机 AI 服务 - 环境变量配置
# ============================================

# --- Agnes AI API ---
# 必填：Agnes AI 的 API Key
AGNES_API_KEY=your_api_key_here

# --- Supabase ---
# 必填：Supabase 项目 URL（格式：https://xxxxx.supabase.co）
SUPABASE_URL=https://your-project.supabase.co

# 必填：Supabase 匿名密钥（anon key）
SUPABASE_KEY=your_anon_key_here

# --- 音频存储 ---
# 可选：音频存储方式，"local"（默认）或 "supabase"
# 设为 "supabase" 时音频上传到 Supabase Storage 的 audio bucket
AUDIO_STORAGE=local

# --- 本地开发 ---
# 仅本地开发使用，Vercel 部署时忽略
SERVER_HOST=0.0.0.0
SERVER_PORT=8765
